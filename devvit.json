{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "appealdesq",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "game.html"
      },
      "mobile": {
        "height": "tall",
        "entry": "mobile.html"
      }
    }
  },
  "media": {
    "dir": "public"
  },
  "marketingAssets": {
    "icon": "public/app-icon.jpg"
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Open AppealDesq",
        "description": "Review structured ban appeals",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-dashboard",
        "postFilter": "none"
      },
      {
        "label": "Open Mobile AppealDesq",
        "description": "Open the mobile-friendly appeal queue",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/open-mobile-dashboard",
        "postFilter": "none"
      }
    ]
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "moderator",
      "asUser": [
        "SUBMIT_POST"
      ]
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onModMail": "/internal/triggers/on-modmail"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "appealdesq_dev"
  }
}
